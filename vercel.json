{
  "version": 2,
  "functions": {
    "api/[...path].ts": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    {
      "source": "/chat",
      "destination": "/api/chat/ask"
    },
    {
      "source": "/chat/:path*",
      "destination": "/api/chat/:path*"
    },
    {
      "source": "/public/uploads/:path*",
      "destination": "/uploads/:path*"
    }
  ]
}
